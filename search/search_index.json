f1a\u63d0\u4f9b\u6240\u6709\u529f\u80fd\u7684\u4ee3\u7801\u5b9e\u73b0\uff0c\u4f46\u4fee\u6539\u914d\u7f6e\u901a\u5e38\u6d89\u53ca\u4ee3\u7801\u7f16\u8f91\u3001\u7f16\u8bd1\u53ca\u56fa\u4ef6\u5237\u5199\uff0c\u64cd\u4f5c\u95e8\u69db\u8f83\u9ad8\u3002</p> <p>VIA \u662f\u63a7\u5236\u5c42\uff1a\u5c06 QMK \u7684\u590d\u6742\u529f\u80fd\u5c01\u88c5\u4e3a\u53ef\u89c6\u5316\u7684\u64cd\u4f5c\u754c\u9762\uff0c\u4f7f\u7528\u6237\u80fd\u591f\u4fbf\u6377\u5730\u8c03\u6574\u952e\u76d8\u914d\u7f6e\uff0c\u6240\u6709\u4fee\u6539\u6700\u7ec8\u4ecd\u7531 QMK \u56fa\u4ef6\u6267\u884c\u3002</p>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#via","title":"\u5982\u4f55\u4f7f\u7528 VIA\uff1f","text":"<p>\u4f7f\u7528 VIA \u914d\u7f6e\u952e\u76d8\u7684\u64cd\u4f5c\u6d41\u7a0b\u5982\u4e0b\uff1a</p> <p>\u786e\u8ba4\u56fa\u4ef6\u652f\u6301\uff1a\u952e\u76d8\u56fa\u4ef6\u9700\u5305\u542b VIA \u652f\u6301\u4ee3\u7801\u3002</p> <p>\u8fde\u63a5\u952e\u76d8\uff1a\u901a\u8fc7\u6570\u636e\u7ebf\u5c06\u952e\u76d8\u8fde\u63a5\u81f3\u7535\u8111\u3002</p> <p>\u8bbf\u95ee\u914d\u7f6e\u5e73\u53f0\uff1a\u6253\u5f00\u6d4f\u89c8\u5668\u8bbf\u95ee via.micah.vip \u5373\u53ef\u5f00\u59cb\u914d\u7f6e\u3002</p> <p>\u9488\u5bf9\u4e0d\u540c\u952e\u76d8\u7684\u517c\u5bb9\u6027\u8bf4\u660e\uff1a</p> <p>\u81ea\u5236\u952e\u76d8\uff1a\u672c\u7f51\u7ad9\u53ef\u76f4\u63a5\u8fde\u63a5\u8bc6\u522b\uff0c\u65e0\u9700\u989d\u5916\u914d\u7f6e\u3002</p> <p>\u5176\u4ed6\u6765\u6e90\u952e\u76d8\uff1a\u82e5\u952e\u76d8\u672a\u88ab\u81ea\u52a8\u8bc6\u522b\uff0c\u53ef\u524d\u5f80\u952e\u76d8\u5236\u9020\u5546\u5b98\u7f51\u4e0b\u8f7d\u5bf9\u5e94\u7684 JSON \u914d\u7f6e\u6587\u4ef6\uff0c\u5728 VIA \u754c\u9762\u7684\u201cDesign\u201d\u6807\u7b7e\u9875\u4e2d\u624b\u52a8\u5bfc\u5165\u8be5\u6587\u4ef6\uff0c\u5373\u53ef\u6b63\u5e38\u4f7f\u7528\u3002</p>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#2viajson","title":"2.VIA\u5bfc\u5165JSON","text":"<p>\u5982\u679c\u4f7f\u7528\u83dc\u7c7d\u732b\u9500\u552e\u7684\u952e\u76d8\u53ef\u4ee5\u8df3\u8fc7\u6b64\u6b65\u9aa4\uff0c\u53ef\u4ee5\u81ea\u52a8\u8bc6\u522b</p> <p>1.\u6253\u5f00\u7f51\u9875 via.micah.vip </p> <p>2.\u70b9\u51fb\u8bbe\u8ba1\uff08\u9f7f\u8f6e\u6309\u94ae\uff09\uff0c\u6253\u5f00Show Design Tab</p> <p></p> <p>3.\u70b9\u51fb\u5237\u5b50\u56fe\u6807\uff08Design\uff09\uff0c\u5207\u6362\u5230Design\u754c\u9762\uff0c\u5355\u673aLoad\u56fe\u6807\uff0c\u9009\u62e9\u5bf9\u5e94\u7684\u952e\u76d8\u7684JSON\u6587\u4ef6</p> <p></p> <p>4.\u6253\u5f00\u540e\u56de\u5230Configure\u754c\u9762\uff0c\u5355\u673aAuthrie Decive\uff0c\u9009\u62e9\u4f60\u4f7f\u7528\u7684\u952e\u76d8</p> <p></p> <p>5.\u786e\u5b9a\u540e\u5373\u53ef\u770b\u5230\u5bf9\u5e94\u7684\u952e\u76d8\u754c\u9762\uff0c\u53ef\u4ee5\u6839\u636e\u81ea\u5df1\u7684\u9700\u6c42\u8fdb\u884c\u6539\u952e\u4e86</p>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#3via","title":"3.VIA\u5b8f\u8bbe\u7f6e","text":""},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#_1","title":"\u5f55\u5236\u5b8f","text":"<p>\u6253\u5f00VIA\u7f51\u9875</p> <p>\u9009\u62e9\u5982\u56fe\u5de6\u4fa7\u5b8f\u6309\u952e\uff0cM0~M15\u4e3a16\u4e2a\u5b8f.</p> <p></p> <p>\u70b9\u51fbFull Screen\u8fdb\u5165\u5168\u5c4f\u6a21\u5f0f\uff0c\u5168\u5c4f\u6a21\u5f0f\u53ef\u4ee5\u5f55\u5236\u6309\u952e</p> <p></p> <p>\u5168\u5c4f\u540e\u70b9\u51fb\u5982\u4e0b\u5f55\u5236\u6309\u94ae\uff0c\u53ef\u4ee5\u8bb0\u5f55\u6309\u4e0b\u7684\u6309\u952e</p> <p></p> <p>\u4ee5Ctrl C\u590d\u5236\u4e3a\u4f8b\uff0c\u6309\u4e0bCtrl+C\u540e\u677e\u5f00\uff0c\u663e\u793a\u5982\u4e0b\u3002\u6309\u4e0b\u505c\u6b62\u6309\u94ae\u540e\uff0c\u5b8c\u6210\u5f55\u5236\uff0c\u7136\u540e\u9000\u51fa\u5168\u5c4f\u6a21\u5f0f </p> <p></p> <p>\u70b9\u51fbSave Changes\uff0c\u8fd9\u4e2a\u5b8f\u5c31\u4fdd\u5b58\u4e86\uff0c\u5982\u56fe\u6211\u4fdd\u5b58\u7684\u4e3aM0\uff0c\u5c31\u662f\u7b2c0\u4e2a\u5b8f </p> <p></p> <p>\u56de\u5230KEYMAP\uff0c\u70b9\u51fbMacro\uff0c\u8fdb\u5165\u5b8f\u6309\u952e\uff0c\u628a\u6211\u4eec\u4fdd\u5b58\u7684\u7b2c0\u4e2a\u5b8f\u4fee\u6539\u5230\u4f60\u60f3\u8981\u4fee\u6539\u7684\u6309\u952e\u90e8\u5206</p> <p></p> <p>\u5982\u56fe\uff0c\u6211\u4fee\u6539\u5230Del\u6309\u952e\uff0c\u6b64\u65f6\u6309\u4e0b\u65f6\u5c31\u5df2\u7ecf\u80fd\u770b\u5230\u89e6\u53d1\u4e86Ctrl+C\u6309\u952e\u4e86</p> <p></p>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#_2","title":"\u624b\u52a8\u5199\u5b8f","text":"<p>1\u3001Win+L \u9501\u5c4f </p> <p>\u6309\u7167\u5982\u4e0b\u56fe\uff0c\u70b9\u51fb\u53f3\u4fa7\u6309\u94ae\u540e\uff0c\u5c06</p> <pre><code>    {+KC_LGUI}l{-KC_LGUI}\n</code></pre> <p>\u4ee3\u7801\u7c98\u8d34\u8fdb\u53bb\u540e\u70b9\u51fbSave\u5c31\u53ef\u4ee5\u751f\u6548</p> <p></p> \u529f\u80fd \u7ec4\u5408\u6309\u952e \u5b8f\u5185\u5bb9 Winlock Win+L {+KC_LGUI}l{-KC_LGUI}"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#any","title":"any\u7684\u7528\u6cd5","text":""},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#qmk-any","title":"QMK \u4e2d\u7684 Any \u952e\u8bf4\u660e","text":"<p>\u5728 QMK \u7684\u4e0a\u4e0b\u6587\u4e2d\uff0c\u201cAny \u952e\u201d\uff08<code>KC_ANY</code> \u6216 <code>ANY()</code>\uff09\u4e0d\u662f\u4e00\u4e2a\u6807\u51c6\u7684\u3001\u6709\u56fa\u5b9a\u529f\u80fd\u7684\u952e\u7801\u3002\u5b83\u7684\u5177\u4f53\u542b\u4e49\u53d6\u51b3\u4e8e\u4f60\u6240\u4f7f\u7528\u7684 QMK \u529f\u80fd\u5206\u652f\uff08\u4e3b\u8981\u662f VIA \u6216 VIAL\uff09\u3002</p>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#_3","title":"\u7b80\u5355\u7406\u89e3","text":"<ul> <li> <p>\u5728 VIA \u4e2d\uff1a<code>ANY</code> \u952e\u662f\u4e00\u4e2a\u5360\u4f4d\u7b26\u6216\u5907\u7528\u7684\"\u5ba2\u5236\u5316\u952e\"\u3002\u5728 VIA \u7684\u56fe\u5f62\u754c\u9762\u91cc\uff0c\u5f53\u4f60\u627e\u4e0d\u5230\u60f3\u8981\u7684\u529f\u80fd\u65f6\uff0c\u53ef\u4ee5\u9009\u62e9 <code>ANY</code>\uff0c\u7136\u540e\u624b\u52a8\u8f93\u5165\u4e00\u4e2a QMK \u80fd\u8bc6\u522b\u7684\u952e\u7801\u6216\u5b8f\u540d\u3002\u4f60\u53ef\u4ee5\u628a\u5b83\u7406\u89e3\u4e3a\u4e00\u4e2a\"\u4ee3\u7801\u6ce8\u5165\u5668\"\uff0c\u8ba9\u4f60\u80fd\u5b9e\u73b0 VIA \u83dc\u5355\u91cc\u6ca1\u6709\u63d0\u4f9b\u7684\u4efb\u610f\u529f\u80fd\u3002</p> </li> <li> <p>\u5728 VIAL \u4e2d\uff1a<code>ANY</code> \u952e\u662f Tap Dance\uff08\u70b9\u6309\u52a8\u4f5c\uff09\u529f\u80fd\u7684\u6838\u5fc3\u90e8\u5206\u3002VIAL \u5141\u8bb8\u4f60\u5728\u4e00\u4e2a\u952e\u4e0a\uff0c\u901a\u8fc7\u5355\u51fb\u3001\u53cc\u51fb\u3001\u6309\u4f4f\u7b49\u4e0d\u540c\u64cd\u4f5c\uff0c\u5206\u914d\u5b8c\u5168\u4e0d\u540c\u7684\u8f93\u51fa\u3002\u8fd9\u91cc\u7684 <code>ANY</code> \u53ef\u4ee5\u7528\u6765\u8f93\u5165\u590d\u6742\u7684\u5b57\u7b26\u4e32\u3001\u5feb\u6377\u952e\u7ec4\u5408\uff0c\u751a\u81f3\u63a7\u5236\u9f20\u6807\u3002\u7b80\u5355\u8bf4\uff0c\u5c31\u662f\u8ba9\u4e00\u4e2a\u952e\u53ef\u4ee5\u5e72\u5f88\u591a\u4ef6\u4e8b\u3002</p> </li> </ul>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#via-vial","title":"VIA \u4e0e VIAL \u5bf9\u6bd4","text":"\u7279\u6027 VIA \u73af\u5883 VIAL \u73af\u5883 \u529f\u80fd\u5b9a\u4f4d \u4e00\u4e2a\u5b9e\u73b0\u975e\u5e38\u89c4/\u4e0d\u5e38\u7528\u529f\u80fd\u7684\"\u4ee3\u7801\u5165\u53e3\" \u914d\u5408 Tap Dance \u529f\u80fd\uff0c\u5b9e\u73b0\u5355\u952e\u591a\u4e49\uff08\u5982\u5355\u51fb\u662fA\uff0c\u53cc\u51fb\u662fB\uff09\u7684\u6838\u5fc3\u5de5\u5177 \u4e3b\u8981\u7528\u9014 \u8f93\u5165 QMK \u6807\u51c6\u4e2d\u6ca1\u6709\uff0c\u4f46\u56fa\u4ef6\u5df2\u5b9e\u73b0\u7684\u7279\u6b8a\u51fd\u6570 \u4e3a\u540c\u4e00\u4e2a\u952e\u5206\u522b\u8bbe\u7f6e\u5355\u51fb\u3001\u53cc\u51fb\u3001\u957f\u6309\u7b49\u4e0d\u540c\u89e6\u53d1\u52a8\u4f5c \u4f7f\u7528\u573a\u666f \u6bd4\u5982\u4f60\u628a\u56fa\u4ef6\u91cc\u7684 <code>MACRO_F6</code> \u624b\u586b\u8fdb <code>ANY</code> \u6846 \u5728 VIAL \u7f16\u8f91\u5668\u7684 Tap Dance \u9009\u9879\u4e2d\uff0c\u4e3a\u4e0d\u540c\u89e6\u53d1\u65b9\u5f0f\u9009\u62e9 <code>ANY</code> \u52a8\u4f5c"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#_4","title":"\u603b\u7ed3","text":"<p>\u5f53\u6709\u4eba\u8bf4\"\u7528 Any \u952e\u5b9e\u73b0\u67d0\u529f\u80fd\"\u65f6\uff0c\u901a\u5e38\u662f\u6307\u5728 VIA/VIAL \u7684\u914d\u7f6e\u754c\u9762\u4e2d\uff0c\u5229\u7528 <code>ANY</code> \u8fd9\u4e2a\u9009\u9879\uff0c\u624b\u52a8\u586b\u5165\u4e00\u4e2a\u81ea\u5b9a\u4e49\u7684\u529f\u80fd\u540d\u79f0\u6216\u952e\u7801\uff0c\u6765\u5b9e\u73b0\u666e\u901a\u83dc\u5355\u91cc\u6ca1\u6709\u7684\u884c\u4e3a\u3002</p>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#_5","title":"\u4f7f\u7528\u65b9\u6cd5","text":"<p>\u627e\u4e00\u4e2a\u6309\u952e\uff0c\u4fee\u6539\u4e3aANY\u6309\u952e</p> <p></p> <p>\u628a\u5982\u4e0b\u952e\u503c\u8f93\u5165\u540eConfirm</p> <pre><code>QK_CLEAR_EEPROM\n</code></pre> <p></p> <p>\u6309\u4e0b\u4fee\u6539\u540e\u7684\u952e\u503c\u5c31\u53ef\u4ee5\u6062\u590d\u51fa\u5382\u8bbe\u7f6e\u4e86</p> <p></p>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.1_VIA/#any_1","title":"\u4e2a\u4eba\u6574\u7406\u7684\u5e38\u7528any\u952e\u503c","text":"\u529f\u80fd \u952e\u503c \u8bf4\u660e \u590d\u5236 LCTL(KC_C) \u7c98\u8d34 LCTL(KC_V) \u6062\u590d\u51fa\u5382\u8bbe\u7f6e QK_CLEAR_EEPROM"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.2%20QA/","title":"Q&amp;A","text":""},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.2%20QA/#_1","title":"\u4ec0\u4e48\u662f\u5168\u952e\u65e0\u51b2\uff1f","text":"<p>\u5168\u952e\u65e0\u51b2\u662f\u201c\u5168\u952e\u76d8\u65e0\u51b2\u7a81\u201d\u7684\u7b80\u79f0\uff0c\u6307\u952e\u76d8\u80fd\u591f\u540c\u65f6\u8bc6\u522b\u5e76\u6309\u987a\u5e8f\u8f93\u51fa\u6240\u6709\u88ab\u6309\u4e0b\u7684\u6309\u952e\uff0c\u4e0d\u4f1a\u51fa\u73b0\u6309\u952e\u4fe1\u53f7\u4e22\u5931\u6216\u51b2\u7a81\u3002</p>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.2%20QA/#1","title":"1. \u4e3a\u4ec0\u4e48\u4f1a\u6709\u201c\u6309\u952e\u51b2\u7a81\u201d\uff1f","text":"<p>\u4f20\u7edf\u952e\u76d8\uff08\u5c24\u5176\u662f\u4f4e\u7aef\u6216\u8001\u65e7\u578b\u53f7\uff09\u7684\u6309\u952e\u77e9\u9635\u7535\u8def\u8bbe\u8ba1\u5b58\u5728\u9650\u5236\u3002\u5f53\u540c\u65f6\u6309\u4e0b\u591a\u4e2a\u6309\u952e\u65f6\uff0c\u7535\u8def\u53ef\u80fd\u65e0\u6cd5\u51c6\u786e\u5224\u65ad\u6bcf\u4e2a\u6309\u952e\u7684\u72b6\u6001\uff0c\u5bfc\u81f4\uff1a</p> <ul> <li>\u6309\u952e\u4e22\u5931\uff1a\u6309\u4e86 4 \u4e2a\u952e\uff0c\u53ea\u8f93\u51fa 3 \u4e2a\u3002</li> <li>\u201c\u9b3c\u952e\u201d\uff1a\u6ca1\u6309\u7684\u952e\u88ab\u8bef\u8bc6\u522b\u5e76\u8f93\u51fa\u3002</li> </ul> <p>\u4f8b\u5982\uff0c\u5728\u65e7\u952e\u76d8\u4e0a\u540c\u65f6\u6309\u4f4f <code>A</code>\u3001<code>S</code>\u3001<code>D</code>\u3001<code>F</code>\uff0c\u53ef\u80fd <code>F</code> \u6ca1\u6709\u53cd\u5e94\uff0c\u751a\u81f3\u51ed\u7a7a\u8f93\u51fa\u4e00\u4e2a <code>Q</code>\u3002</p>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.2%20QA/#2","title":"2. \u5168\u952e\u65e0\u51b2\u7684\u7ea7\u522b","text":"\u7c7b\u578b \u8bf4\u660e \u5e38\u89c1\u573a\u666f 6 \u952e\u65e0\u51b2 (6KRO) \u6700\u591a\u540c\u65f6\u8bc6\u522b 6 \u4e2a\u6309\u952e\uff08\u542b\u4fee\u9970\u952e\u5982 Ctrl\u3001Shift\uff09 \u7edd\u5927\u591a\u6570\u529e\u516c\u952e\u76d8\u3001\u666e\u901a USB \u952e\u76d8 \u5168\u952e\u65e0\u51b2 (NKRO) \u53ef\u540c\u65f6\u8bc6\u522b\u6240\u6709\u6309\u952e\uff0c\u7406\u8bba\u6700\u9ad8 100+ \u952e \u6e38\u620f\u952e\u76d8\u3001\u673a\u68b0\u952e\u76d8\u3001\u9ad8\u7aef\u952e\u76d8"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.2%20QA/#3","title":"3. \u5168\u952e\u65e0\u51b2\u6709\u4ec0\u4e48\u7528\uff1f","text":"<ul> <li>\u6e38\u620f\u573a\u666f\uff1a\u683c\u6597\u6e38\u620f\uff08\u8fde\u62db\uff09\u3001\u97f3\u6e38\uff08\u591a\u952e\u540c\u6309\uff09\u3001FPS\uff08\u540c\u65f6\u6309 Shift+W+Space+\u9f20\u6807\u7b49\uff09\u65f6\u9700\u8981\u7cbe\u786e\u8bc6\u522b\u6bcf\u4e2a\u6309\u952e\u3002</li> <li>\u5feb\u901f\u6253\u5b57 / \u7ec4\u5408\u64cd\u4f5c\uff1a\u907f\u514d\u5feb\u6377\u952e\u8bef\u5224\u3002</li> <li>\u591a\u4eba\u540c\u673a / \u7279\u6b8a\u8f93\u5165\uff1a\u4f8b\u5982\u4e24\u4eba\u5171\u7528\u4e00\u952e\u76d8\u73a9\u540c\u4e00\u6e38\u620f\u3002</li> </ul>"},{"location":"6_%E4%BD%BF%E7%94%A8%E6%95%99%E7%A8%8B/6.2%20QA/#4","title":"4. \u6ce8\u610f\u4e8b\u9879","text":"<ul> <li>\u5927\u591a\u6570\u73b0\u4ee3\u673a\u68b0\u952e\u76d8\u9ed8\u8ba4\u5df2\u652f\u6301\u5168\u952e\u65e0\u51b2\uff08\u6216\u53ef\u901a\u8fc7\u5feb\u6377\u952e\u5207\u6362\u56de 6 \u952e\u65e0\u51b2\uff0c\u4ee5\u517c\u5bb9\u8001\u65e7 BIOS \u6216\u67d0\u4e9b\u7a0b\u5e8f\uff09\u3002</li> <li>\u901a\u8fc7 USB \u53ef\u4ee5\u5b9e\u73b0 NKRO\uff0c\u4f46\u6781\u4e2a\u522b\u8001\u65e7\u4e3b\u677f\u6216\u7cfb\u7edf\u53ef\u80fd\u9700\u8981 PS/2 \u63a5\u53e3\u624d\u80fd\u5b8c\u5168\u65e0\u51b2\uff08\u7f55\u89c1\uff09\u3002</li> <li>\u5f00\u542f\u5168\u952e\u65e0\u51b2\u4e0d\u4f1a\u635f\u574f\u952e\u76d8\uff0c\u4f46\u82e5\u9047\u5230\u517c\u5bb9\u6027\u95ee\u9898\uff08\u5982\u67d0\u4e9b\u6e38\u620f\u6216\u8fdc\u7a0b\u684c\u9762\u8f93\u5165\u5f02\u5e38\uff09\uff0c\u53ef\u4ee5\u5207\u6362\u56de 6 \u952e\u65e0\u51b2\u3002</li> </ul> <p>\u5982\u679c\u4f60\u60f3\u786e\u8ba4\u5f53\u524d\u952e\u76d8\u662f\u5426\u5904\u4e8e\u5168\u952e\u65e0\u51b2\u6a21\u5f0f\uff0c\u53ef\u4ee5\u7528\u5728\u7ebf\u952e\u76d8\u6d4b\u8bd5\u5de5\u5177\uff08\u5982 \u201cKeyboard Test Utility\u201d \u6216 \u201cMicrosoft \u952e\u76d8\u6d4b\u8bd5\u201d\uff09\uff0c\u540c\u65f6\u6309\u4e0b\u591a\u4e2a\u6309\u952e\u67e5\u770b\u662f\u5426\u5168\u90e8\u88ab\u8bc6\u522b\u3002</p>"}]}